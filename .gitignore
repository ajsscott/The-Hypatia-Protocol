# ===========================================
# Hypatia Protocol .gitignore
# ===========================================

# Kiro runtime config (legacy; substrate is now Roo Code; .kiro/ is no longer
# created by setup.sh but kept gitignored if accidentally generated)
.kiro/

# Claude
.claude/
CLAUDE.md

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
*.egg-info/

# Node
node_modules/

# Secrets & Credentials
.env
.env.*
!.env.example
*.pem
*.key
*.cert
secrets.json
credentials.json

# IDE & Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Temporary
*.tmp
*.swp
*.bak
*.log

# Vectorstore (generated, rebuildable)
hypatia-kb/vectorstore/vectors.npy
hypatia-kb/vectorstore/metadata.json
hypatia-kb/vectorstore/config.json

# Hypothesis test cache
hypatia-kb/vectorstore/.hypothesis/
.pytest_cache/

# Hypatia scratch space (logs, drafts, queued ingests; per-machine, not curated)
workspace/*
!workspace/README.md

# Generated markdown exports (rebuilt on every save-session from JSON stores)
hypatia-kb/exports/

# Rust build artifacts
target/
Cargo.lock.bak

# Tauri build output
frontend/src-tauri/gen/
frontend/dist/

# Generated Goose system prompt (regenerated by goose-config/regen-system-prompt.sh)
goose-config/system-prompt.md
